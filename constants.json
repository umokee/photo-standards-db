{
  "users": {
    "roles": ["operator", "inspector", "admin"],
    "defaults": { "role": "operator" }
  },
  "standards": {
    "angles": ["front", "top", "left", "right", "back"]
  },
  "inspections": {
    "statuses": ["passed", "failed"],
    "modes": ["photo", "snapshot", "realtime"],
    "defaults": { "status": "passed", "mode": "photo" }
  },
  "training": {
    "statuses": ["pending", "preparing", "training", "saving", "done", "failed"],
    "activeStatuses": ["pending", "preparing", "training", "saving"],
    "architectures": [{ "value": "yolov26n-seg", "baseWeights": "yolo26n-seg.pt" }],
    "imageSizes": [320, 416, 512, 640, 768, 1024, 1280],
    "defaults": {
      "architecture": "yolov26n-seg",
      "epochs": 100,
      "batchSize": 16,
      "imageSize": 640,
      "trainRatio": 80,
      "valRatio": 10,
      "status": "pending"
    },
    "limits": {
      "epochs": { "min": 1, "max": 1000 },
      "batchSize": { "min": 1, "max": 256 },
      "trainRatio": { "min": 60, "max": 80 },
      "valRatio": { "min": 10, "max": 20 },
      "ratioSumMax": 100,
      "minImagesToTrain": 3
    }
  },
  "segments": {
    "hue": {
      "default": 210,
      "min": 0,
      "max": 359
    }
  },
  "uploads": {
    "allowedTypes": ["image/jpeg", "image/png", "image/jpg"],
    "maxSizeBytes": 20971520
  }
}
