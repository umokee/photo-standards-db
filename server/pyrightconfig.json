{
  "include": ["src"],
  "exclude": [".venv", "**/__pycache__"],
  "pythonVersion": "3.13",
  "venvPath": ".",
  "venv": ".venv",
  "pythonPlatform": "Linux",
  "typeCheckingMode": "basic",
  "autoImportCompletions": true,
  "indexing": true,
  "extraPaths": ["src"],
  "executionEnvironments": [
    {
      "root": "src",
      "extraPaths": ["src"]
    }
  ]
}
